generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int            @id @default(autoincrement())
  email                String         @unique
  password             String
  role                 Role           @default(USER)
  createdAt            DateTime       @default(now())
  about                String?
  attributes           Json?
  businessAddress      String?
  businessDescription  String?
  businessIndustry     String?
  clientId             String?
  contactEmail         String?
  firstName            String?
  image                String?
  lastName             String?
  phoneNumber          String?
  tags                 String[]
  updatedAt            DateTime       @updatedAt
  website1             String?
  website2             String?
  accessToken          String?
  refreshToken         String?
  accessTokenExpiresAt Int?
  chatbots             Chatbot[]
  contacts             Contact[]
  conversations        Conversation[]
  templates            Template[]
  teams                Team[]         @relation("UserTeams")
  chatStatusChanges    ChatStatusHistory[] 
  businessAccount   BusinessAccount?
}

model BusinessAccount {
  id                 Int      @id @default(autoincrement())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Link back to User
  userId             Int      @unique
  user               User     @relation(fields: [userId], references: [id])

  // Screenshot-1 fields
  timeZone           String?  // e.g. "Asia/Kolkata"
  businessName       String?  // e.g. "Durga Medicals"
  businessVerification String? // e.g. "Verified", "Unverified"
  accountStatus      String?  // e.g. "Approved", "Pending"
  paymentMethod      String?  // e.g. "VISA ****" or "PayPal"

  // Meta-specific fields
  metaAccessToken    String?
  metaWabaId         String?

  // One business account can have multiple phone numbers
  phoneNumbers       BusinessPhoneNumber[]
}

model BusinessPhoneNumber {
  id                Int      @id @default(autoincrement())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Link back to BusinessAccount
  businessAccountId Int
  businessAccount   BusinessAccount @relation(fields: [businessAccountId], references: [id])

  // Screenshot-2 fields (example placeholders)
  phoneNumber       String?   // e.g. "+91 98181 28065"
  metaPhoneNumberId String    // e.g. "115045638165610"
  displayName       String?   // e.g. "Sesame Workshop India"
  connectionStatus  String?   // e.g. "CONNECTED"
  subscription      String?   // e.g. "Free", "Premium"
}
model Team {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  defaultTeam Boolean   @default(false)
  size        Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  contacts    Contact[] @relation("ContactTeams")
  users       User[]    @relation("UserTeams")
}

model Message {
  id             Int           @id @default(autoincrement())
  conversationId Int?
  contactId      Int
  sender         String
  text           String?
  time           DateTime      @default(now())
  links          String[]
  attachment     String?
  subMessages    Json?
  status         MessageStatus @default(SENT)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  chatbotId      Int?
  messageType    String        @default("text")
  buttonOptions  Json?
  listItems      Json?
  chatbot        Chatbot?      @relation("ChatbotMessages", fields: [chatbotId], references: [id])
  contact        Contact       @relation(fields: [contactId], references: [id])
  conversation   Conversation?  @relation(fields: [conversationId], references: [id])
   templateId     Int?         // Store reference to template
  template       Template?    @relation(fields: [templateId], references: [id])  
}

model Contact {
  id                                                              Int                 @id @default(autoincrement())
  name                                                            String?
  phoneNumber                                                     String              @unique
  email                                                           String?
  source                                                          String
  userId                                                          Int?
  tags                                                            String[]
  attributes                                                      Json?
  createdAt                                                       DateTime            @default(now())
  updatedAt                                                       DateTime            @updatedAt
  sendSMS                                                         Boolean?            @default(false)
  subscribed                                                      Boolean?            @default(false)
  user                                                            User?               @relation(fields: [userId], references: [id])
  conversations                                                   Conversation[]
  messages                                                        Message[]
  notes                                                           Note[]
  assignedTeams                                                   Team[]              @relation("ContactTeams")

    // ✅ Chat Status Tracking
  ticketStatus         String?              // Stores current chat status ("Open", "Pending", "Expired", etc.)
  latestChatStatusId   Int?                 @unique
  chatStatusHistory    ChatStatusHistory[]  // Relation to track all status changes

  // ✅ Timer Tracking
  lastMessageTime      DateTime?            // Timestamp of the last received message
  timerStartTime       DateTime?            // When the timer last started
  timerEndTime         DateTime? 
}

model Note {
  id        Int      @id @default(autoincrement())
  contactId Int
  content   String
  createdAt DateTime @default(now())
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Chatbot {
  id            Int            @id @default(autoincrement())
  name          String
  description   String?
  triggered     Boolean?       @default(false)
  stepsFinished Int?
  finished      Boolean?       @default(false)
  startNodeId   Int?           @unique
  ownerId       Int?
  status        Status         @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  owner         User?          @relation(fields: [ownerId], references: [id])
  startNode     Node?          @relation("StartNode", fields: [startNodeId], references: [id])
  conversations Conversation[]
  edges         Edge[]         @relation("ChatbotEdges")
  keywords      Keyword[]
  messages      Message[]      @relation("ChatbotMessages")
  nodes         Node[]         @relation("ChatbotNodes")
  variables     Variable[]
}

model Node {
  id           Int        @id @default(autoincrement())
  nodeId       String
  data         Json
  createdAt    DateTime   @default(now())
  positionX    Float
  positionY    Float
  type         String
  updatedAt    DateTime   @updatedAt
  chatId       Int
  startChatbot Chatbot?   @relation("StartNode")
  edgesOut     Edge[]     @relation("SourceNode")
  edgesIn      Edge[]     @relation("TargetNode")
  chatbot      Chatbot    @relation("ChatbotNodes", fields: [chatId], references: [id])
  variables    Variable[]
}

model Edge {
  id           Int      @id @default(autoincrement())
  chatId       Int
  sourceId     Int
  targetId     Int
  sourceHandle String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  chatbot      Chatbot  @relation("ChatbotEdges", fields: [chatId], references: [id])
  source       Node     @relation("SourceNode", fields: [sourceId], references: [id])
  target       Node     @relation("TargetNode", fields: [targetId], references: [id])
}

model Variable {
  id             Int           @id @default(autoincrement())
  name           String
  value          String?
  chatbotId      Int
  conversationId Int?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  nodeId         Int?
  chatbot        Chatbot       @relation(fields: [chatbotId], references: [id])
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  node           Node?         @relation(fields: [nodeId], references: [id])
}

model Conversation {
  id                     Int                 @id @default(autoincrement())
  recipient              String
  chatbotId              Int?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  currentNodeId          Int?
  lastNodeId             Int?
  userId                 Int?
  answeringQuestion      Boolean             @default(false)
  validationFailureCount Int                 @default(0)
  contactId              Int?
  chatStatus             String?
  ChatStatusHistory      ChatStatusHistory[]
  chatbot                Chatbot?            @relation(fields: [chatbotId], references: [id])
  contact                Contact?            @relation(fields: [contactId], references: [id])
  user                   User?               @relation(fields: [userId], references: [id])
  messages               Message[]
  variables              Variable[]
}

model Keyword {
  id           Int           @id @default(autoincrement())
  value        String        @unique
  chatbotId    Int?
  textId       Int?
  matchType    MatchType
  fuzzyPercent Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  chatbot      Chatbot?      @relation(fields: [chatbotId], references: [id])
  text         TextMaterial? @relation(fields: [textId], references: [id])
}

model Template {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  language  String   @default("en_US")
  content   String?
  userId    Int
  category  String
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?     @relation(fields: [userId], references: [id])
  messages  Message[]
}

model TextMaterial {
  id        Int       @id @default(autoincrement())
  name      String
  content   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now())
  keywords  Keyword[]
}

model ChatStatusHistory {
  id                                                    Int           @id @default(autoincrement())
  contactId                                             Int
  contact    Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  previousStatus String?
  newStatus      String
  changedById    Int?       // ✅ Foreign key reference to User (Agent or Bot)
   changedBy     User? @relation(fields: [changedById], references: [id], onDelete: SetNull)

  createdAt                                             DateTime      @default(now())
  changedAt      DateTime  @default(now())

  timerStartTime DateTime?  // ✅ Only updates when a new message is received
  timerEndTime   DateTime?

  conversationId                                        Int?
  Conversation                                          Conversation? @relation(fields: [conversationId], references: [id])
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum ChatStatus {
  OPENED
  EXPIRED
  SOLVED
  PENDING
  IN_PROGRESS
}

enum Role {
  SUPERADMIN
  ANALYST
  USER
  BOTCREATOR
  BOT
}

enum Status {
  ACTIVE
  INACTIVE
}

enum MatchType {
  FUZZY
  EXACT
  CONTAINS
}
