generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HubspotIntegration {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique // One HubSpot integration per user
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt Int? // Unix timestamp
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])
}

model Webhook {
  id                    Int                 @id @default(autoincrement())
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  url                   String
  status                String
  eventTypes            String
  businessPhoneNumberId Int
  businessPhoneNumber   BusinessPhoneNumber @relation(fields: [businessPhoneNumberId], references: [id])
}

model User {
  id                    Int                 @id @default(autoincrement())
  email                 String              @unique
  password              String
  role                  Role                @default(USER)
  createdAt             DateTime            @default(now())
  about                 String?
  attributes            String[]
  businessAddress       String?
  businessDescription   String?
  businessIndustry      String?
  clientId              String?
  contactEmail          String?
  firstName             String?
  image                 String?
  lastName              String?
  phoneNumber           String?
  tags                  String[]
  updatedAt             DateTime            @updatedAt
  website1              String?
  website2              String?
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  Int?
  emailVerified         Boolean             @default(false)
  verificationToken     String?
  resetToken            String?
  resetTokenExpiresAt   DateTime?
  apiKey                String?
  chatbots              Chatbot[]
  contacts              Contact[]
  conversations         Conversation[]
  templates             Template[]
  teams                 Team[]              @relation("UserTeams")
  chatStatusChanges     ChatStatusHistory[]
  assignedTickets       ChatStatusHistory[] @relation("AssignedToUser")
  businessAccount       BusinessAccount[]
  selectedPhoneNumberId String?
  selectedWabaId        String?
  agent                 Boolean?            @default(false)
  createdById           Int?
  createdBy             User?               @relation("CreatedUsers", fields: [createdById], references: [id])
  createdUsers          User[]              @relation("CreatedUsers")
  isOnline              Boolean             @default(false)
  lastActive            DateTime?
  rules                 Rule[]
  payments              Payment[]
  packageSubscriptions  PackageSubscription[] // New relation

  // ✅ New relations for RoutingMaterial assignments
  receivedMaterials    RoutingMaterial[]     @relation("RoutingMaterialUsers") // For Notification type
  assignedMaterials    RoutingMaterial[]     @relation("RoutingMaterialAssignedUser") // For AssignUser type
  keywords             Keyword[]
  hubspotIntegration   HubspotIntegration?
  notificationSettings NotificationSetting[]
  contactsCreated   Contact[] @relation("ContactCreatedBy")
  metaBusinessToken   String?
  billingInformation  BillingInformation?
  media               Media[]
}

model BusinessAccount {
  id                   Int                   @id @default(autoincrement())
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  userId               Int
  user                 User                  @relation(fields: [userId], references: [id])
  timeZone             String?
  businessName         String?
  businessVerification String?
  accountStatus        String?
  paymentMethod        String?
  metaAccessToken      String?
  metaWabaId           String?
  phoneNumbers         BusinessPhoneNumber[]
  workingHours         Json?
  language             String?
  contentDirection     String?
  holidayMode          Boolean?              @default(false)
  supportButtonEnabled Boolean?              @default(false)
  supportButtonWebsite String?
}

model Rule {
  id          Int      @id @default(autoincrement())
  name        String
  triggerType String // e.g. "whatsappMessage", "attributeAdded", etc.
  action      String // e.g. "sendTemplate", "sendMessage", etc.
  status      String   @default("Active") // "Active" or "Inactive"
  executed    Int      @default(0) // Number of times the rule has been executed
  lastUpdated DateTime @default(now()) @updatedAt
  createdAt   DateTime @default(now())

  // Rule conditions and actions data (stored as JSON)
  conditions Json? // Filters and conditions
  actionData Json? // Details specific to the action type

  // Who created the rule
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

//the rule under the businessPhoneNumber
  businessPhoneNumberId Int
  businessPhoneNumber   BusinessPhoneNumber @relation(fields: [businessPhoneNumberId], references: [id], onDelete: Cascade)

  @@index([userId])
   @@index([businessPhoneNumberId])
}

model BusinessPhoneNumber {
  id                    Int                    @id @default(autoincrement())
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  businessAccountId     Int
  businessAccount       BusinessAccount        @relation(fields: [businessAccountId], references: [id])
  phoneNumber           String?
  metaPhoneNumberId     String                 @unique
  displayName           String?
  connectionStatus      String?
  subscription          String?
  conversations         Conversation[]
  defaultActionSettings DefaultActionSettings?
  webhooks              Webhook[]
  notificationSetting   NotificationSetting?
  fallbackEnabled       Boolean                @default(false)
  fallbackMessage       String?
  fallbackTriggerCount  Int                    @default(3)
  fallbackHitCount      Int                    @default(0)
  rules                 Rule[]
  replyMaterials        ReplyMaterial[]
  roundRobinState       RoundRobinState?
  media                 Media[]
}

model NotificationSetting {
  id                    Int                  @id @default(autoincrement())
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  businessPhoneNumberId Int?                 @unique
  businessPhoneNumber   BusinessPhoneNumber? @relation(fields: [businessPhoneNumberId], references: [id])

  // Desktop notifications
  newChatDesktop          Boolean @default(true)
  newMessageDesktop       Boolean @default(true)
  assignedAgentDesktop    Boolean @default(true)
  messageAssignedDesktop  Boolean @default(true)
  chatAssignedTeamDesktop Boolean @default(true)

  // Sound notifications
  newChatSound          Boolean @default(true)
  newMessageSound       Boolean @default(true)
  assignedAgentSound    Boolean @default(true)
  messageAssignedSound  Boolean @default(true)
  chatAssignedTeamSound Boolean @default(true)

  // Sound option
  selectedSound String @default("Alert")
  userId        Int?   @unique
  user          User?  @relation(fields: [userId], references: [id])
}

model DefaultActionSettings {
  id                    Int                 @id @default(autoincrement())
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  businessPhoneNumberId Int                 @unique
  businessPhoneNumber   BusinessPhoneNumber @relation(fields: [businessPhoneNumberId], references: [id])

  workingHours Json? // ✅ Stores working hours in JSON

  // ✅ Default action settings (Boolean fields)
  outsideWorkingHoursEnabled Boolean @default(false) // When it is not working hours
  noAgentOnlineEnabled       Boolean @default(false) // When no customer service is online
  waitingMessageEnabled      Boolean @default(false) // keep user angaged while delay reply from business side
  fallbackMessageEnabled     Boolean @default(false) // When no keyword or default action match
  welcomeMessageEnabled      Boolean @default(false) // When no keyword match
  noResponseAfter24hEnabled  Boolean @default(false) // If customer does not respond

  // ✅ Selected material/chatbot/template for default actions
  outsideWorkingHoursMaterialId   Int? // Associated material/chatbot/template
  outsideWorkingHoursMaterialType String? // Type: chatbot, template, sticker, etc.

  noAgentOnlineMaterialId   Int?
  noAgentOnlineMaterialType String?

  fallbackMessageMaterialId   Int?
  fallbackMessageMaterialType String?

  welcomeMessageMaterialId   Int?
  welcomeMessageMaterialType String?

  waitingMessageMaterialId   Int?
  waitingMessageMaterialType String?

  noResponseAfter24hMaterialId   Int?
  noResponseAfter24hMaterialType String?

  // ✅ Additional settings from pic-2 (Boolean fields)
  expiredChatReassignmentDisabled Boolean @default(false) // Expired chat not reassigned
  noKeywordMatchReplyEnabled      Boolean @default(false) // Reply after X minutes if no match
  roundRobinAssignmentEnabled     Boolean @default(false) // Assign chats in round-robin
}

model Team {
  id               Int                 @id @default(autoincrement())
  name             String              @unique
  defaultTeam      Boolean             @default(false)
  size             Int
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  contacts         Contact[]           @relation("ContactTeams")
  users            User[]              @relation("UserTeams")
  assignedTickets  ChatStatusHistory[]
  routingMaterials RoutingMaterial[]   @relation("RoutingMaterialTeam")
}

model Message {
  id             Int           @id @default(autoincrement())
  conversationId Int?
  contactId      Int
  sender         String
  text           String?
  time           DateTime      @default(now())
  links          String[]
  attachment     String?
  subMessages    Json?
  status         MessageStatus @default(SENT)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  chatbotId      Int?
  messageType    String        @default("text")
  buttonOptions  Json?
  listItems      Json?
  chatbot        Chatbot?      @relation("ChatbotMessages", fields: [chatbotId], references: [id])
  contact        Contact       @relation(fields: [contactId], references: [id])
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  templateId     Int?
  template       Template?     @relation(fields: [templateId], references: [id])
}

model Broadcast {
  id                Int                  @id @default(autoincrement())
  name              String
  templateName      String
  userId            Int
  phoneNumberId     String? // e.g. your BusinessPhoneNumber metaPhoneNumberId
  createdAt         DateTime             @default(now())
  scheduledDateTime DateTime? // When the broadcast is scheduled to be sent
  sentAt            DateTime? // When the broadcast was actually sent
  status            String               @default("PENDING") // Values: PENDING, SCHEDULED, SENT, FAILED
  recipients        BroadcastRecipient[]
}

model BroadcastRecipient {
  id          Int             @id @default(autoincrement())
  broadcast   Broadcast       @relation(fields: [broadcastId], references: [id])
  broadcastId Int
  contact     Contact         @relation(fields: [contactId], references: [id])
  contactId   Int
  status      BroadcastStatus @default(SENT)
  createdAt   DateTime        @default(now())
  errorMessage String?
}

enum BroadcastStatus {
  PENDING
  SCHEDULED
  SENT
  DELIVERED
  READ
  FAILED
}

model Contact {
  id                 Int                 @id @default(autoincrement())
  name               String?
  phoneNumber        String              @unique
  email              String?
  source             String
  userId             Int?
  tags               String[]
  attributes         Json?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  sendSMS            Boolean?            @default(false)
  subscribed         Boolean?            @default(false)
  // ✅ Assigned Agent
  user               User?               @relation(fields: [userId], references: [id])
  conversations      Conversation[]
  messages           Message[]
  notes              Note[]
  assignedTeams      Team[]              @relation("ContactTeams")
  ticketStatus       String?
  latestChatStatusId Int?                @unique
  chatStatusHistory  ChatStatusHistory[]

  lastMessageTime DateTime?
  timerStartTime  DateTime?
  timerEndTime    DateTime?
  broadcasts      BroadcastRecipient[]
  createdById        Int?
  createdBy          User?               @relation("ContactCreatedBy", fields: [createdById], references: [id])
}

model Note {
  id        Int      @id @default(autoincrement())
  contactId Int
  content   String
  createdAt DateTime @default(now())
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Chatbot {
  id            Int            @id @default(autoincrement())
  name          String
  description   String?
  triggered     Int?          @default(0)
  stepsFinished Int?          @default(0)
  finished      Int?          @default(0)
  startNodeId   Int?           @unique
  ownerId       Int?
  status        Status         @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  owner         User?          @relation(fields: [ownerId], references: [id])
  startNode     Node?          @relation("StartNode", fields: [startNodeId], references: [id])
  conversations Conversation[]
  edges         Edge[]         @relation("ChatbotEdges")
  keywords      Keyword[]
  messages      Message[]      @relation("ChatbotMessages")
  nodes         Node[]         @relation("ChatbotNodes")
  variables     Variable[]
}

model Node {
  id           Int        @id @default(autoincrement())
  nodeId       String
  data         Json
  createdAt    DateTime   @default(now())
  positionX    Float
  positionY    Float
  type         String
  updatedAt    DateTime   @updatedAt
  chatId       Int
  startChatbot Chatbot?   @relation("StartNode")
  edgesOut     Edge[]     @relation("SourceNode")
  edgesIn      Edge[]     @relation("TargetNode")
  chatbot      Chatbot    @relation("ChatbotNodes", fields: [chatId], references: [id])
  variables    Variable[]
}

model Edge {
  id           Int      @id @default(autoincrement())
  chatId       Int
  sourceId     Int
  targetId     Int
  sourceHandle String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  chatbot      Chatbot  @relation("ChatbotEdges", fields: [chatId], references: [id])
  source       Node     @relation("SourceNode", fields: [sourceId], references: [id])
  target       Node     @relation("TargetNode", fields: [targetId], references: [id])
}

model Variable {
  id             Int           @id @default(autoincrement())
  name           String
  value          String?
  chatbotId      Int
  conversationId Int?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  nodeId         Int?
  chatbot        Chatbot       @relation(fields: [chatbotId], references: [id])
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  node           Node?         @relation(fields: [nodeId], references: [id])
}

model Conversation {
  id                     Int                  @id @default(autoincrement())
  recipient              String
  chatbotId              Int?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  currentNodeId          Int?
  lastNodeId             Int?
  userId                 Int?
  answeringQuestion      Boolean              @default(false)
  validationFailureCount Int                  @default(0)
  contactId              Int?
  chatStatus             String?
  ChatStatusHistory      ChatStatusHistory[]
  chatbot                Chatbot?             @relation(fields: [chatbotId], references: [id])
  contact                Contact?             @relation(fields: [contactId], references: [id])
  user                   User?                @relation(fields: [userId], references: [id])
  messages               Message[]
  variables              Variable[]
  businessPhoneNumberId  Int?
  businessPhoneNumber    BusinessPhoneNumber? @relation(fields: [businessPhoneNumberId], references: [id])
}

model Keyword {
  id               Int                      @id @default(autoincrement())
  value            String                   @unique
  chatbotId        Int?
  textId           Int?
  matchType        MatchType
  fuzzyPercent     Int?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  chatbot          Chatbot?                 @relation(fields: [chatbotId], references: [id])
  userId           Int?
  user             User?                    @relation(fields: [userId], references: [id])
  replyMaterials   KeywordReplyMaterial[]
  routingMaterials KeywordRoutingMaterial[]
  keywordTemplates KeywordTemplate[]
}

model KeywordReplyMaterial {
  id              Int @id @default(autoincrement())
  keywordId       Int
  replyMaterialId Int

  keyword       Keyword       @relation(fields: [keywordId], references: [id])
  replyMaterial ReplyMaterial @relation(fields: [replyMaterialId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model KeywordRoutingMaterial {
  id                Int @id @default(autoincrement())
  keywordId         Int
  routingMaterialId Int

  keyword         Keyword         @relation(fields: [keywordId], references: [id])
  routingMaterial RoutingMaterial @relation(fields: [routingMaterialId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Template {
  id               Int               @id @default(autoincrement())
  name             String            @unique
  language         String            @default("en_US")
  content          String?
  userId           Int
  category         String
  status           String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User?             @relation(fields: [userId], references: [id])
  messages         Message[]
  wabaId           String?
  keywordTemplates KeywordTemplate[]
}

model KeywordTemplate {
  id         Int      @id @default(autoincrement())
  keywordId  Int
  templateId Int
  keyword    Keyword  @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ReplyMaterial {
  id        Int                    @id @default(autoincrement())
  type      MaterialType
  name      String
  content   String?
  fileUrl   String?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  keywords  KeywordReplyMaterial[]
  businessPhoneNumberId  Int?
  businessPhoneNumber    BusinessPhoneNumber? @relation(fields: [businessPhoneNumberId], references: [id])

}

model RoutingMaterial {
  id           Int         @id @default(autoincrement())
  type         RoutingType
  materialName String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // ✅ Relations for notification and assignments
  users          User[] @relation("RoutingMaterialUsers") // For Notification type
  assignedUser   User?  @relation("RoutingMaterialAssignedUser", fields: [assignedUserId], references: [id]) // For AssignUser type
  assignedUserId Int?

  team     Team?                    @relation("RoutingMaterialTeam", fields: [teamId], references: [id]) // For AssignTeam type
  teamId   Int?
  keywords KeywordRoutingMaterial[]
}

enum RoutingType {
  Notification
  AssignUser
  AssignTeam
}

model ChatStatusHistory {
  id        Int     @id @default(autoincrement())
  contactId Int
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  previousStatus String?
  newStatus      String
  changedById    Int? // ✅ Foreign key reference to User (Agent or Bot)
  changedBy      User?   @relation(fields: [changedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  changedAt DateTime @default(now())

  timerStartTime DateTime? // ✅ Only updates when a new message is received
  timerEndTime   DateTime?

  type String  @default("statusChanged") // "statusChanged" | "assignmentChanged"
  note String?

  assignedToUserId Int? // Optional, use if you want to store who it's assigned to
  assignedToUser   User? @relation("AssignedToUser", fields: [assignedToUserId], references: [id])

  assignedToTeamId Int?
  assignedToTeam   Team? @relation(fields: [assignedToTeamId], references: [id])

  conversationId Int?
  Conversation   Conversation? @relation(fields: [conversationId], references: [id])
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum ChatStatus {
  OPENED
  EXPIRED
  SOLVED
  PENDING
  IN_PROGRESS
}

enum Role {
  SUPERADMIN
  ANALYST
  USER
  BOTCREATOR
  BOT
}

enum Status {
  ACTIVE
  INACTIVE
}

enum MatchType {
  FUZZY
  EXACT
  CONTAINS
}

enum MaterialType {
  TEXT
  IMAGE
  VIDEO
  DOCUMENT
  STICKER
  CONTACT_ATTRIBUTES
  Notification
  AssignUser
  AssignTeam
}

model Payment {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
  orderId       String   @unique
  paymentId     String?  @unique
  amount        Int
  currency      String   @default("INR")
  status        String   @default("PENDING") // PENDING, SUCCESS, FAILED
  paymentType   String   @default("upgrade-package") // New field for payment type
  metadata      Json     // New field to store packageName and packageDuration
  signature     String?
  lastFourDigits String? // Last four digits of the card/account
  cardType      String?  // Type of card/account (e.g., "visa", "mastercard", "upi", "netbanking")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  packageSubscription PackageSubscription? // New relation
}

model PackageSubscription {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  paymentId   Int      @unique
  payment     Payment  @relation(fields: [paymentId], references: [id])
  packageName String
  startDate   DateTime @default(now())
  endDate     DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model RoundRobinState {
  id                String   @id @default(cuid())
  phoneNumberId     String   @unique
  lastAssignedIndex Int
  businessPhoneNumber BusinessPhoneNumber @relation(fields: [phoneNumberId], references: [metaPhoneNumberId])
}

model BillingInformation {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email       String
  firstName   String
  lastName    String
  company     String?
  countryCode String
  mobileNumber String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Media {
  id                    Int                 @id @default(autoincrement())
  url                   String
  fileName              String?
  fileType              String?
  fileSize              Int?
  mimeType              String?
  userId                Int
  businessPhoneNumberId Int?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  
  // Relations
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessPhoneNumber   BusinessPhoneNumber? @relation(fields: [businessPhoneNumberId], references: [id], onDelete: SetNull)
}
