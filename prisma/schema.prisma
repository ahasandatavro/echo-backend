generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HubspotIntegration {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt Int?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])
}

model Webhook {
  id                    Int                 @id @default(autoincrement())
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  url                   String
  status                String
  eventTypes            String
  businessPhoneNumberId Int
  businessPhoneNumber   BusinessPhoneNumber @relation(fields: [businessPhoneNumberId], references: [id])
  webhookLogs           WebhookLog[]
}

model User {
  id                    Int                   @id @default(autoincrement())
  email                 String                @unique
  password              String
  role                  Role                  @default(USER)
  createdAt             DateTime              @default(now())
  about                 String?
  businessAddress       String?
  businessDescription   String?
  businessIndustry      String?
  clientId              String?
  contactEmail          String?
  firstName             String?
  image                 String?
  lastName              String?
  phoneNumber           String?
  tags                  String[]
  updatedAt             DateTime              @updatedAt
  website1              String?
  website2              String?
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  Int?
  selectedPhoneNumberId String?
  selectedWabaId        String?
  attributes            String[]
  agent                 Boolean?              @default(false)
  createdById           Int?
  isOnline              Boolean               @default(false)
  lastActive            DateTime?
  emailVerified         Boolean               @default(false)
  verificationToken     String?
  resetToken            String?
  resetTokenExpiresAt   DateTime?
  metaBusinessToken     String?
  apiKey                String?
  billingInformation    BillingInformation?
  businessAccount       BusinessAccount[]
  assignedTickets       ChatStatusHistory[]   @relation("AssignedToUser")
  chatStatusChanges     ChatStatusHistory[]
  chatbots              Chatbot[]
  contactsCreated       Contact[]             @relation("ContactCreatedBy")
  contacts              Contact[]
  conversations         Conversation[]
  hubspotIntegration    HubspotIntegration?
  keywords              Keyword[]
  media                 Media[]
  notificationSettings  NotificationSetting?
  packageSubscriptions  PackageSubscription[]
  payments              Payment[]
  assignedMaterials     RoutingMaterial[]     @relation("RoutingMaterialAssignedUser")
  rules                 Rule[]
  templates             Template[]
  createdBy             User?                 @relation("CreatedUsers", fields: [createdById], references: [id])
  createdUsers          User[]                @relation("CreatedUsers")
  receivedMaterials     RoutingMaterial[]     @relation("RoutingMaterialUsers")
  teams                 Team[]                @relation("UserTeams")
}

model BusinessAccount {
  id                   Int                   @id @default(autoincrement())
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  userId               Int
  timeZone             String?
  businessName         String?
  businessVerification String?
  accountStatus        String?
  paymentMethod        String?
  metaAccessToken      String?
  metaWabaId           String?
  workingHours         Json?
  contentDirection     String?
  holidayMode          Boolean?              @default(false)
  language             String?
  supportButtonEnabled Boolean?              @default(false)
  supportButtonWebsite String?
  user                 User                  @relation(fields: [userId], references: [id])
  phoneNumbers         BusinessPhoneNumber[]
}

model Rule {
  name                  String
  triggerType           String
  action                String
  status                String              @default("Active")
  executed              Int                 @default(0)
  lastUpdated           DateTime            @default(now()) @updatedAt
  createdAt             DateTime            @default(now())
  conditions            Json?
  actionData            Json?
  userId                Int
  id                    Int                 @id @default(autoincrement())
  businessPhoneNumberId Int
  businessPhoneNumber   BusinessPhoneNumber @relation(fields: [businessPhoneNumberId], references: [id], onDelete: Cascade)
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([businessPhoneNumberId])
}

model BusinessPhoneNumber {
  id                    Int                    @id @default(autoincrement())
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  businessAccountId     Int
  phoneNumber           String?
  metaPhoneNumberId     String                 @unique
  displayName           String?
  connectionStatus      String?
  subscription          String?
  fallbackEnabled       Boolean                @default(false)
  fallbackMessage       String?
  fallbackTriggerCount  Int                    @default(3)
  fallbackHitCount      Int                    @default(0)
  timeoutMinutes            Int      @default(30) 
  enableExitNotification    Boolean  @default(false)
  exitNotificationMessage   String   @default("Please type or select from the options above if you would like to continue, else this conversation will reset and you may have to share your responses again.")
  exitNotificationLeadTime  Int      @default(5)
  businessAccount       BusinessAccount        @relation(fields: [businessAccountId], references: [id])
  conversations         Conversation[]
  defaultActionSettings DefaultActionSettings?
  media                 Media[]
  notificationSetting   NotificationSetting?
  replyMaterials        ReplyMaterial[]
  roundRobinState       RoundRobinState?
  rules                 Rule[]
  webhooks              Webhook[]
  webhookLogs           WebhookLog[]
}

model NotificationSetting {
  id                      Int                  @id @default(autoincrement())
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  businessPhoneNumberId   Int?                 @unique
  newChatDesktop          Boolean              @default(true)
  newMessageDesktop       Boolean              @default(true)
  assignedAgentDesktop    Boolean              @default(true)
  messageAssignedDesktop  Boolean              @default(true)
  chatAssignedTeamDesktop Boolean              @default(true)
  newChatSound            Boolean              @default(true)
  newMessageSound         Boolean              @default(true)
  assignedAgentSound      Boolean              @default(true)
  messageAssignedSound    Boolean              @default(true)
  chatAssignedTeamSound   Boolean              @default(true)
  selectedSound           String               @default("Alert")
  userId                  Int?                 @unique
  businessPhoneNumber     BusinessPhoneNumber? @relation(fields: [businessPhoneNumberId], references: [id])
  user                    User?                @relation(fields: [userId], references: [id])
}

model DefaultActionSettings {
  id                              Int                 @id @default(autoincrement())
  createdAt                       DateTime            @default(now())
  updatedAt                       DateTime            @updatedAt
  businessPhoneNumberId           Int                 @unique
  workingHours                    Json?
  outsideWorkingHoursEnabled      Boolean             @default(false)
  noAgentOnlineEnabled            Boolean             @default(false)
  fallbackMessageEnabled          Boolean             @default(false)
  noResponseAfter24hEnabled       Boolean             @default(false)
  outsideWorkingHoursMaterialId   Int?
  outsideWorkingHoursMaterialType String?
  noAgentOnlineMaterialId         Int?
  noAgentOnlineMaterialType       String?
  fallbackMessageMaterialId       Int?
  fallbackMessageMaterialType     String?
  noResponseAfter24hMaterialId    Int?
  noResponseAfter24hMaterialType  String?
  expiredChatReassignmentDisabled Boolean             @default(false)
  noKeywordMatchReplyEnabled      Boolean             @default(false)
  roundRobinAssignmentEnabled     Boolean             @default(false)
  waitingMessageEnabled           Boolean             @default(false)
  waitingMessageMaterialId        Int?
  waitingMessageMaterialType      String?
  welcomeMessageEnabled           Boolean             @default(false)
  welcomeMessageMaterialId        Int?
  welcomeMessageMaterialType      String?
  businessPhoneNumber             BusinessPhoneNumber @relation(fields: [businessPhoneNumberId], references: [id])
}

model Team {
  id               Int                 @id @default(autoincrement())
  name             String              @unique
  defaultTeam      Boolean             @default(false)
  size             Int
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  assignedTickets  ChatStatusHistory[]
  routingMaterials RoutingMaterial[]   @relation("RoutingMaterialTeam")
  contacts         Contact[]           @relation("ContactTeams")
  users            User[]              @relation("UserTeams")
}

model Message {
  id             Int           @id @default(autoincrement())
  conversationId Int?
  contactId      Int
  sender         String
  text           String?
  time           DateTime      @default(now())
  links          String[]
  attachment     String?
  subMessages    Json?
  status         MessageStatus @default(SENT)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  chatbotId      Int?
  messageType    String        @default("text")
  buttonOptions  Json?
  listItems      Json?
  templateId     Int?
  chatbot        Chatbot?      @relation("ChatbotMessages", fields: [chatbotId], references: [id])
  contact        Contact       @relation(fields: [contactId], references: [id])
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  template       Template?     @relation(fields: [templateId], references: [id])
}

model Broadcast {
  id                Int                  @id @default(autoincrement())
  name              String
  templateName      String
  userId            Int
  phoneNumberId     String?
  createdAt         DateTime             @default(now())
  sentAt            DateTime?
  status            String               @default("PENDING")
  scheduledDateTime DateTime?
  recipients        BroadcastRecipient[]
  
  // MM Lite API Analytics Fields
  totalSent         Int                  @default(0)
  totalDelivered    Int                  @default(0)
  totalRead         Int                  @default(0)
  totalClicked      Int                  @default(0)
  totalReplied      Int                  @default(0)
  websiteClicks     Int                  @default(0)
  buttonClicks      Json?                // Store button-wise click data
  apiType           String               @default("CLOUD") // "CLOUD" or "MM_LITE"
  templateId        String?              // Meta template ID for MM Lite tracking
  
  // Metrics tracking
  metrics           BroadcastMetric[]
}
model BroadcastRecipientHistory {
  id                    Int             @id @default(autoincrement())
  broadcastRecipientId  Int
  status                BroadcastStatus
  errorMessage          String?
  createdAt             DateTime        @default(now())
  broadcastRecipient    BroadcastRecipient @relation(fields: [broadcastRecipientId], references: [id], onDelete: Cascade)
  
  @@index([broadcastRecipientId])
  @@index([createdAt])
}
model TemplateClick {
  id         Int      @id @default(autoincrement())
  templateId Int      @unique
  clickCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
}
model BroadcastRecipient {
  id           Int             @id @default(autoincrement())
  broadcastId  Int
  contactId    Int
  status       BroadcastStatus @default(SENT)
  createdAt    DateTime        @default(now())
  errorMessage String?
  broadcast    Broadcast       @relation(fields: [broadcastId], references: [id])
  contact      Contact         @relation(fields: [contactId], references: [id])
  history      BroadcastRecipientHistory[]
}

model BroadcastMetric {
  id          Int       @id @default(autoincrement())
  broadcastId Int
  metricType  String    // "sent", "delivered", "read", "clicked", "replied", "button_click"
  metricValue Int       @default(1)
  contactId   Int?      // Optional: track per contact
  buttonId    String?   // For button click tracking
  timestamp   DateTime  @default(now())
  
  broadcast   Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  contact     Contact?  @relation(fields: [contactId], references: [id])
}

model Contact {
  id                 Int                  @id @default(autoincrement())
  name               String?
  phoneNumber        String               @unique
  email              String?
  source             String
  userId             Int?
  tags               String[]
  attributes         Json?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  sendSMS            Boolean?             @default(false)
  subscribed         Boolean?             @default(false)
  latestChatStatusId Int?                 @unique
  lastMessageTime    DateTime?
  ticketStatus       String?
  timerEndTime       DateTime?
  timerStartTime     DateTime?
  createdById        Int?
  broadcasts         BroadcastRecipient[]
  broadcastMetrics   BroadcastMetric[]
  chatStatusHistory  ChatStatusHistory[]
  createdBy          User?                @relation("ContactCreatedBy", fields: [createdById], references: [id])
  user               User?                @relation(fields: [userId], references: [id])
  conversations      Conversation[]
  messages           Message[]
  notes              Note[]
  assignedTeams      Team[]               @relation("ContactTeams")
  nodeVisits NodeVisit[] 
}

model Note {
  id        Int      @id @default(autoincrement())
  contactId Int
  content   String
  createdAt DateTime @default(now())
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Chatbot {
  id            Int            @id @default(autoincrement())
  name          String
  description   String?
  stepsFinished Int?           @default(0)
  startNodeId   Int?           @unique
  ownerId       Int?
  status        Status         @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  triggered     Int?           @default(0)
  finished      Int?           @default(0)
  owner         User?          @relation(fields: [ownerId], references: [id])
  startNode     Node?          @relation("StartNode", fields: [startNodeId], references: [id])
  conversations Conversation[]
  edges         Edge[]         @relation("ChatbotEdges")
  keywords      Keyword[]
  messages      Message[]      @relation("ChatbotMessages")
  nodes         Node[]         @relation("ChatbotNodes")
  variables     Variable[]
}

model Node {
  id           Int        @id @default(autoincrement())
  nodeId       String
  data         Json
  createdAt    DateTime   @default(now())
  positionX    Float
  positionY    Float
  type         String
  updatedAt    DateTime   @updatedAt
  chatId       Int
  startChatbot Chatbot?   @relation("StartNode")
  edgesOut     Edge[]     @relation("SourceNode")
  edgesIn      Edge[]     @relation("TargetNode")
  chatbot      Chatbot    @relation("ChatbotNodes", fields: [chatId], references: [id])
  variables    Variable[]
  nodeVisits NodeVisit[]
}

model Edge {
  id           Int      @id @default(autoincrement())
  chatId       Int
  sourceId     Int
  targetId     Int
  sourceHandle String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  chatbot      Chatbot  @relation("ChatbotEdges", fields: [chatId], references: [id])
  source       Node     @relation("SourceNode", fields: [sourceId], references: [id])
  target       Node     @relation("TargetNode", fields: [targetId], references: [id])
}

model Variable {
  id             Int           @id @default(autoincrement())
  name           String
  value          String?
  chatbotId      Int
  conversationId Int?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  nodeId         Int?
  chatbot        Chatbot       @relation(fields: [chatbotId], references: [id])
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  node           Node?         @relation(fields: [nodeId], references: [id])
}
model NodeVisit {
  id             Int          @id @default(autoincrement())
  conversationId Int
  nodeId         Int
  contactId      Int?
  enteredAt      DateTime     @default(now())
  leftAt         DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  node           Node         @relation(fields: [nodeId], references: [id])
  contact        Contact?     @relation(fields: [contactId], references: [id])
}
model Conversation {
  id                     Int                  @id @default(autoincrement())
  recipient              String
  chatbotId              Int?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  currentNodeId          Int?
  lastNodeId             Int?
  userId                 Int?
  answeringQuestion      Boolean              @default(false)
  validationFailureCount Int                  @default(0)
  contactId              Int?
  chatStatus             String?
  businessPhoneNumberId  Int?
  waitingJobId           String?              // Job ID for waiting message
  lastAgentMessageAt     DateTime?            // Timestamp of last agent message
  waitingMessageSent     Boolean              @default(false) // Flag to track if waiting message was sent
  noResponse24hJobId     String?              // Job ID for 24-hour no response action
  lastCustomerMessageAt  DateTime?            // Timestamp of last customer message
  noResponse24hSent      Boolean              @default(false) // Flag to track if 24h action was sent
  ChatStatusHistory      ChatStatusHistory[]
  businessPhoneNumber    BusinessPhoneNumber? @relation(fields: [businessPhoneNumberId], references: [id])
  chatbot                Chatbot?             @relation(fields: [chatbotId], references: [id])
  contact                Contact?             @relation(fields: [contactId], references: [id])
  user                   User?                @relation(fields: [userId], references: [id])
  messages               Message[]
  variables              Variable[]
  nodeVisits NodeVisit[]
}

model Keyword {
  id               Int                      @id @default(autoincrement())
  value            String                   @unique
  chatbotId        Int?
  textId           Int?
  matchType        MatchType
  fuzzyPercent     Int?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  userId           Int?
  chatbot          Chatbot?                 @relation(fields: [chatbotId], references: [id])
  user             User?                    @relation(fields: [userId], references: [id])
  replyMaterials   KeywordReplyMaterial[]
  routingMaterials KeywordRoutingMaterial[]
  keywordTemplates KeywordTemplate[]
}

model KeywordReplyMaterial {
  id              Int           @id @default(autoincrement())
  keywordId       Int
  replyMaterialId Int
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  keyword         Keyword       @relation(fields: [keywordId], references: [id])
  replyMaterial   ReplyMaterial @relation(fields: [replyMaterialId], references: [id])
}

model KeywordRoutingMaterial {
  id                Int             @id @default(autoincrement())
  keywordId         Int
  routingMaterialId Int
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  keyword           Keyword         @relation(fields: [keywordId], references: [id])
  routingMaterial   RoutingMaterial @relation(fields: [routingMaterialId], references: [id])
}

model Template {
  id               Int               @id @default(autoincrement())
  name             String            @unique
  language         String            @default("en_US")
  content          String?
  userId           Int
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  category         String
  status           String
  wabaId           String?
  keywordTemplates KeywordTemplate[]
  messages         Message[]
  user             User              @relation(fields: [userId], references: [id])
  rejectionError   String?
  templateClick    TemplateClick?
}

model KeywordTemplate {
  id         Int      @id @default(autoincrement())
  keywordId  Int
  templateId Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  keyword    Keyword  @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model ReplyMaterial {
  id                    Int                    @id @default(autoincrement())
  type                  MaterialType
  name                  String
  content               String?
  fileUrl               String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  businessPhoneNumberId Int?
  keywords              KeywordReplyMaterial[]
  businessPhoneNumber   BusinessPhoneNumber?   @relation(fields: [businessPhoneNumberId], references: [id])
}

model RoutingMaterial {
  id             Int                      @id @default(autoincrement())
  type           RoutingType
  materialName   String
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  assignedUserId Int?
  teamId         Int?
  keywords       KeywordRoutingMaterial[]
  assignedUser   User?                    @relation("RoutingMaterialAssignedUser", fields: [assignedUserId], references: [id])
  team           Team?                    @relation("RoutingMaterialTeam", fields: [teamId], references: [id])
  users          User[]                   @relation("RoutingMaterialUsers")
}

model ChatStatusHistory {
  id               Int           @id @default(autoincrement())
  contactId        Int
  conversationId   Int?
  changedAt        DateTime      @default(now())
  createdAt        DateTime      @default(now())
  changedById      Int?
  newStatus        String
  previousStatus   String?
  timerEndTime     DateTime?
  timerStartTime   DateTime?
  assignedToTeamId Int?
  assignedToUserId Int?
  note             String?
  type             String        @default("statusChanged")
  assignedToTeam   Team?         @relation(fields: [assignedToTeamId], references: [id])
  assignedToUser   User?         @relation("AssignedToUser", fields: [assignedToUserId], references: [id])
  changedBy        User?         @relation(fields: [changedById], references: [id])
  contact          Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  Conversation     Conversation? @relation(fields: [conversationId], references: [id])
}

model Payment {
  id                  Int                  @id @default(autoincrement())
  userId              Int
  orderId             String               @unique
  paymentId           String?              @unique
  amount              Int
  currency            String               @default("INR")
  status              String               @default("PENDING")
  signature           String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  metadata            Json
  paymentType         String               @default("upgrade-package")
  cardType            String?
  lastFourDigits      String?
  packageSubscription PackageSubscription?
  user                User                 @relation(fields: [userId], references: [id])
}

model PackageSubscription {
  id          Int      @id @default(autoincrement())
  userId      Int
  paymentId   Int      @unique
  packageName String
  startDate   DateTime @default(now())
  endDate     DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  payment     Payment  @relation(fields: [paymentId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model RoundRobinState {
  id                  String              @id @default(cuid())
  phoneNumberId       String              @unique
  lastAssignedIndex   Int
  businessPhoneNumber BusinessPhoneNumber @relation(fields: [phoneNumberId], references: [metaPhoneNumberId])
}

model BillingInformation {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  email        String
  firstName    String
  lastName     String
  company      String?
  countryCode  String
  mobileNumber String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Media {
  id                    Int                  @id @default(autoincrement())
  url                   String
  fileName              String?
  fileType              String?
  fileSize              Int?
  mimeType              String?
  userId                Int
  businessPhoneNumberId Int?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  businessPhoneNumber   BusinessPhoneNumber? @relation(fields: [businessPhoneNumberId], references: [id])
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WebhookLog {
  id                    Int                 @id @default(autoincrement())
  webhookId             Int
  requestUrl            String
  requestMethod         String              @default("POST")
  requestHeaders        Json?
  requestBody           Json?
  requestTimestamp      DateTime            @default(now())
  responseStatus        Int?
  responseHeaders       Json?
  responseBody          Json?
  responseTime          Int?
  status                WebhookLogStatus    @default(PENDING)
  retryCount            Int                 @default(0)
  maxRetries            Int                 @default(3)
  errorMessage          String?
  errorType             String?
  eventType             String
  businessPhoneNumberId Int
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  businessPhoneNumber   BusinessPhoneNumber @relation(fields: [businessPhoneNumberId], references: [id])
  webhook               Webhook             @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([status])
  @@index([createdAt])
  @@index([businessPhoneNumberId])
}

enum BroadcastStatus {
  SENT
  DELIVERED
  READ
  FAILED
  PENDING
  SCHEDULED
}

enum RoutingType {
  Notification
  AssignUser
  AssignTeam
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum ChatStatus {
  OPENED
  EXPIRED
  SOLVED
  PENDING
  IN_PROGRESS
}

enum Role {
  SUPERADMIN
  ANALYST
  USER
  BOTCREATOR
  BOT
}

enum Status {
  ACTIVE
  INACTIVE
}

enum MatchType {
  FUZZY
  EXACT
  CONTAINS
}

enum MaterialType {
  TEXT
  IMAGE
  VIDEO
  DOCUMENT
  STICKER
  CONTACT_ATTRIBUTES
  Notification
  AssignUser
  AssignTeam
}

enum WebhookLogStatus {
  PENDING
  SUCCESS
  FAILED
  RETRYING
  MAX_RETRIES_EXCEEDED
}
